{
    "name": "komodo",
    "version": "0.1.0",
    "description": "A rich terminal UI for managing docker-compose / Makefile projects",
    "type": "module",
    "bin": {
        "komodo": "./dist/komodo"
    },
    "scripts": {
        "dev": "bun run src/cli.tsx",
        "start": "bun run src/cli.tsx",
        "build": "bun build src/cli.tsx --compile --outfile dist/komodo",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "ink": "^5.1.0",
        "ink-spinner": "^5.0.0",
        "react": "^18.3.1",
        "yaml": "^2.6.1"
    },
    "devDependencies": {
        "@types/react": "^18.3.12",
        "bun-types": "^1.1.38",
        "typescript": "^5.7.2"
    }
}
